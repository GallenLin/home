EXPORT_PATH=

# export $HOME/bin
EXPORT_PATH="${HOME}/home/bin:${HOME}/bin"
#EXPORT_PATH="/opt/tools/bin:${EXPORT_PATH}"

# export common arm cross-compiles bin .
EXPORT_PATH="/opt/arm-2008q3/bin:${EXPORT_PATH}"

# export freescale arm mx35 cross-compiles bin .
EXPORT_PATH="/opt/freescale/usr/local/gcc-4.1.2-glibc-2.5-nptl-3/arm-none-linux-gnueabi/bin:${EXPORT_PATH}"

# export marvell arm cross-compiles v2 bin .
EXPORT_PATH="/opt/marvell/arm-marvell-linux-gnueabi_4.2/bin:${EXPORT_PATH}"

# export marvell arm cross-compiles v1 bin .
#EXPORT_PATH="/opt/marvell/arm-marvell-linux-gnueabi/bin:${EXPORT_PATH}"

# export freescale arm mx6 cross-compiles bin .
EXPORT_PATH="/opt/freescale/usr/local/gcc-4.6.2-glibc-2.13-linaro-multilib-2011.12/fsl-linaro-toolchain/bin:${EXPORT_PATH}"

# export freescale arm mx50 cross-compiles bin .
EXPORT_PATH="/opt/freescale/usr/local/gcc-4.4.4-glibc-2.11.1-multilib-1.0/arm-fsl-linux-gnueabi/bin:${EXPORT_PATH}"

# export openrisc cross-compiles & or1ksim bin .
EXPORT_PATH="${EXPORT_PATH}:/opt/or1k-toolchain/bin:/opt/or1ksim/bin"


# export android tools bin .
ANDROID_SDK_ROOT="/home/${USER}/android/sdk"
EXPORT_PATH="${ANDROID_SDK_ROOT}/tools:${ANDROID_SDK_ROOT}/platform-tools:${EXPORT_PATH}"
echo "Please put android sdk in \"${ANDROID_SDK_ROOT}\""

# export mips cross-compile bin for JZ project .
#EXPORT_PATH="/opt/mipseltools-gcc412-glibc261/bin:${EXPORT_PATH}"

if [ -z "$(echo $PATH|grep "${EXPORT_PATH}")" ];then
	export PATH=$PATH:$EXPORT_PATH
fi

alias gvim="gvim -f"

if [ -z "${USER}" ];then
	# for docker .
	echo "USER empty , set it by whoami ."
	export USER="$(whoami)"
fi

if [ "$(ls "/home/${USER}/.mydocker_latest_container_name")" ];then
	MYDOCKER_WORK_CONTAINER="$(cat "/home/${USER}/.mydocker_latest_container_name")"
	export MYDOCKER_WORK_CONTAINER
else
	export MYDOCKER_WORK_CONTAINER="gallen_work-191106"
fi
export MYDOCKER_WORK_IMAGE="ubuntu:16.04-b300-lichee-droid-sdmk-ok"
export MYDOCKER_WORK_USER="work"

